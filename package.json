{
  "name": "csc-reviewer",
  "version": "0.1.0",
  "private": true,
  "description": "Digitized mock Career Service Examination Professional reviewer app for a small group of examinees.",
  "type": "module",
  "scripts": {
    "check": "node --check app/app.js && node --check app/paper-mode.js && node --check app/admin.js",
    "check:admin": "node scripts/check-admin-console.mjs",
    "check:resume": "node scripts/check-resume-persistence.mjs",
    "setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-local-deps.ps1",
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start.ps1",
    "validate:data": "node scripts/validate-static-data.mjs",
    "audit:questions": "node scripts/audit-question-bank.mjs",
    "qa:states": "node scripts/qa-cockpit.cjs qa/current-states",
    "qa:interactions": "node scripts/qa-interactions.cjs qa/current-interactions",
    "qa:motion": "node scripts/qa-motion.cjs qa/current-motion",
    "qa:compare": "node scripts/qa-reference-report.cjs qa/current-states",
    "qa:paper": "node scripts/qa-paper-mode.cjs qa/current-paper-mode"
  }
}
