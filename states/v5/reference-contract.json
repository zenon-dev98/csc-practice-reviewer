{
  "version": "v5",
  "canvas": { "width": 1672, "height": 942 },
  "target": {
    "browser": "Microsoft Edge",
    "zoom": "100%",
    "window": "maximized",
    "desktopViewports": ["1672x942", "1904x913", "1536x816", "1536x736", "1366x768"],
    "mobileViewports": ["390x844", "412x915"]
  },
  "shared": {
    "brandSelector": ".brand",
    "primaryPanelSelectors": [".card", ".hub-panel", ".v3-panel", ".question-panel", "[role='dialog']"],
    "minimumDesktopFontPx": { "body": 14, "metadata": 12, "button": 14, "fieldLabel": 13 },
    "minimumMobileFontPx": { "body": 14, "metadata": 12, "button": 14, "fieldLabel": 13 },
    "minimumControlHeightPx": { "desktop": 34, "mobile": 44 },
    "minimumIconPlatePx": { "primary": 46, "secondary": 20 },
    "semanticColors": {
      "general": "purple",
      "verbal": "cyan",
      "numerical": "blue",
      "analytical": "green",
      "warning": "amber",
      "danger": "red"
    }
  },
  "contracts": [
    { "id": "system-loading", "states": ["loading"], "reference": "system_loading.png", "approval": "approved", "shell": "system", "anchors": [".system-screen"] },
    { "id": "system-error", "states": ["config", "fatal"], "reference": "system_error.png", "approval": "approved", "shell": "system", "anchors": [".system-screen"] },
    { "id": "create-account", "states": ["create", "create-loading"], "reference": "create_account.png", "approval": "approved", "shell": "public", "anchors": [".auth-canvas", ".auth-card"] },
    { "id": "sign-in", "states": ["select", "signin-loading"], "reference": "sign_in.png", "approval": "approved", "shell": "public", "anchors": [".auth-canvas", ".auth-card"] },
    { "id": "forgot-password", "states": ["forgot-password", "forgot-error", "forgot-success"], "reference": "forgot_password-draft.png", "approval": "draft", "shell": "public-modal", "anchors": ["[role='dialog']"], "approvedDeviation": "Remember-me control is retired." },
    { "id": "study-hub", "states": ["dashboard", "dashboard-empty"], "reference": "../v4/study_hub.png", "approval": "approved", "shell": "signed-in", "anchors": [".study-hub", ".hub-run-panel", ".hub-records-panel"] },
    { "id": "mock-setup", "states": ["setup"], "reference": "full_mock_setup.png", "approval": "approved", "shell": "signed-in", "anchors": [".setup-page", ".setup-facts", ".setup-options"] },
    { "id": "active-exam", "states": ["exam", "exam-collapsed", "long-prompt", "long-choices"], "reference": "exam_active.png", "approval": "approved", "shell": "exam", "anchors": [".exam-shell", ".exam-nav", ".question-panel"], "scrollOwner": ".exam-nav" },
    { "id": "stimulus-exam", "states": ["graph", "passage", "data-table", "metric-bars", "line-chart", "series-line", "series-bars"], "reference": "exam_graph.png", "approval": "approved", "shell": "exam", "anchors": [".exam-shell", ".stimulus-panel", ".question-panel"], "scrollOwner": ".stimulus-content" },
    { "id": "stimulus-modal", "states": ["chart-modal", "passage-modal", "table-modal", "line-modal"], "reference": "chart_modal.png", "approval": "approved", "shell": "exam-modal", "anchors": [".chart-modal"], "scrollOwner": ".chart-modal" },
    { "id": "exam-pause", "states": ["pause"], "reference": "exam_pause.png", "approval": "approved", "shell": "exam-modal", "anchors": [".pause-modal"] },
    { "id": "exam-submit", "states": ["submit"], "reference": "exam_submit.png", "approval": "approved", "shell": "exam-modal", "anchors": [".submit-modal"] },
    { "id": "exam-timeout", "states": ["timeout"], "reference": "exam_timeout.png", "approval": "approved", "shell": "exam-modal", "anchors": [".timeout-modal"] },
    { "id": "practice-builder", "states": ["practice"], "reference": "practice_review_practice.png", "approval": "approved", "shell": "signed-in", "anchors": [".practice-review-page", ".practice-mode-cards"] },
    { "id": "mistakes", "states": ["mistakes"], "reference": "practice_review_mistakes.png", "approval": "approved", "shell": "signed-in", "anchors": [".practice-review-page", ".mistake-list"], "scrollOwner": ".mistake-attempt-scroll" },
    { "id": "mistakes-empty", "states": ["mistakes-empty"], "reference": "practice_review_mistakes_empty.png", "approval": "approved", "shell": "signed-in", "anchors": [".practice-review-page"] },
    { "id": "flagged", "states": ["flagged"], "reference": "practice_review_flagged.png", "approval": "approved", "shell": "signed-in", "anchors": [".practice-review-page", ".review-queue"], "scrollOwner": ".review-queue" },
    { "id": "flagged-empty", "states": ["flagged-empty"], "reference": "practice_review_flagged_empty.png", "approval": "approved", "shell": "signed-in", "anchors": [".practice-review-page"] },
    { "id": "progress", "states": ["recent", "progress"], "reference": "progress.png", "approval": "approved", "shell": "signed-in", "anchors": [".progress-page", ".attempt-table"], "scrollOwner": ".attempt-table" },
    { "id": "progress-empty", "states": ["progress-empty"], "reference": "progress_empty.png", "approval": "approved", "shell": "signed-in", "anchors": [".progress-page"] },
    { "id": "results-pass", "states": ["results"], "reference": "results_fail.png", "approval": "approved", "shell": "signed-in-contextual", "anchors": [".results-page", ".score-gauge", ".run-insights-panel"], "approvedDeviation": "Passing status uses green while retaining fail-screen geometry." },
    { "id": "results-fail", "states": ["results-fail"], "reference": "results_fail.png", "approval": "approved", "shell": "signed-in-contextual", "anchors": [".results-page", ".score-gauge", ".run-insights-panel"] },
    { "id": "results-practice", "states": ["results-practice"], "reference": "results_practice.png", "approval": "approved", "shell": "signed-in-contextual", "anchors": [".results-page", ".score-gauge", ".run-insights-panel"] },
    { "id": "answer-review", "states": ["review"], "reference": "answer_review.png", "approval": "approved", "shell": "signed-in-contextual", "anchors": [".review-page", ".review-navigator-console", ".review-question-panel"], "scrollOwner": ".review-question-scroll" },
    { "id": "answer-review-empty", "states": ["review-empty"], "reference": "answer_review_empty.png", "approval": "approved", "shell": "signed-in-contextual", "anchors": [".review-page", ".review-navigator-console", ".review-question-panel"] },
    { "id": "account-settings", "states": ["profile-modal"], "reference": "account_settings.png", "approval": "approved", "shell": "signed-in-drawer", "anchors": [".account-settings-modal"], "scrollOwner": ".account-settings-modal" },
    { "id": "password-dialog", "states": ["password-expanded"], "reference": "account_password_dialog.png", "approval": "approved", "shell": "signed-in-modal", "anchors": [".password-modal"] },
    { "id": "delete-account", "states": ["delete-account"], "reference": "account_delete_confirmation.png", "approval": "approved", "shell": "signed-in-modal", "anchors": [".account-delete-confirm"] },
    { "id": "delete-attempt", "states": ["delete-attempt"], "reference": "delete_attempt.png", "approval": "approved", "shell": "signed-in-modal", "anchors": [".attempt-delete-confirm"] }
  ]
}
